PYTHON="/path/to/your/python"  # e.g. /opt/homebrew/bin/python3 or /path/to/venv/bin/python
WORKDIR="/path/to/ostracon-ai"  # absolute path to this repository

cd "$WORKDIR"

# Pass all selected files in a single invocation so the progress window
# can display overall progress across the whole batch.
result=$("$PYTHON" biblio_agent.py --window --no-move "$@" 2>&1)
exit_code=$?

if [ $exit_code -ne 0 ] && [ -n "$result" ]; then
    osascript -e "display alert \"Bibliography Extraction Failed\" message \"${result}\" as critical"
fi

printf '%s' "$result"
