	Author = Xxxxx,
	Title = Xxxxx,
	Shorttitle = Xxxxx,
	Translator = Xxxxx,
	Journaltitle = Xxxxx,
	Volume = Xxxxx,
	Number = Xxxxx,
	Pages = Xxxxx,
	Date = Xxxxx,
	Url = Xxxxx,
	Doi = Xxxxx,
	Keywords = Xxxxx,
	Read = Xxxxx,
}

