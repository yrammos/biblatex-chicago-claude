% --- Example book review type ---
% Fields: author, date, doi, journaltitle, number, pages, shorttitle, title, url, volume
% Note the use of \bibstring{reviewof} followed by the title of the reviewed book within `\mkbibemph{...}`, followed by comma, followed by `\bibstring{by}`, followed by the name of the book author (not the review author).
@review{Dunsby1997,
	Author = {Dunsby, Jonathan},
	Title = {\bibstring{reviewof} \mkbibemph{Authenticities: Philosophical Reflections on Musical Performance}, \bibstring{by} Peter Kivy},
	Journaltitle = {Music \& Letters},
	Date = {1997},
	Keywords = {crit-authenticity-realism},
	Shorttitle = {\bibstring{reviewof} \mkbibemph{Authenticities}, \bibstring{by} Kivy},
	Pages = {132-135},
	Volume = {78},
	Number = {1},
}

